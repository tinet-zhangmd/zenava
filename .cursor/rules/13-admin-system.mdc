## 数据库管理

### 数据库配置

#### MySQL 配置 (生产环境)
```typescript
// src/lib/mysql.ts
import mysql from 'mysql2/promise'

export async function createMySQLPool() {
  return mysql.createPool({
    host: process.env.MYSQL_HOST || 'localhost',
    port: parseInt(process.env.MYSQL_PORT || '3306'),
    user: process.env.MYSQL_USER || 'root',
    password: process.env.MYSQL_PASSWORD || '',
    database: process.env.MYSQL_DATABASE || 'ZENAVA_LOCAL',
    charset: 'utf8mb4',
    waitForConnections: true,
    connectionLimit: 10,
    queueLimit: 0
  })
}
```

#### SQLite 配置 (开发环境)
```typescript
// src/adapters/database.ts
export function createD1CompatibleDatabase(dbPath?: string) {
  const path = dbPath || process.env.DB_PATH || 'data/zenava.db'
  const db = new Database(path)
  db.pragma('foreign_keys = ON')
  return new SQLiteD1Adapter(db)
}
```

