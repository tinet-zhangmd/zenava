### 添加新的 API 端点

#### 1. 创建 API 文件
```typescript
// src/api/new-feature.tsx
import { Hono } from 'hono'

const newFeatureApi = new Hono()

// 获取数据
newFeatureApi.get('/', async (c) => {
  try {
    const results = await c.env.DB.prepare(
      'SELECT * FROM new_feature_table'
    ).all()
    
    return c.json({ success: true, data: results })
  } catch (error: any) {
    return c.json({ success: false, error: error.message }, 500)
  }
})

// 创建数据
newFeatureApi.post('/', async (c) => {
  try {
    const data = await c.req.json()
    
    const result = await c.env.DB.prepare(
      'INSERT INTO new_feature_table (name, value) VALUES (?, ?)'
    ).bind(data.name, data.value).run()
    
    return c.json({ success: true, data: { id: result.meta.last_row_id } })
  } catch (error: any) {
    return c.json({ success: false, error: error.message }, 500)
  }
})

export default newFeatureApi
```

#### 2. 注册 API 路由
```typescript
// src/index.tsx
import newFeatureApi from './api/new-feature'

app.route('/api/new-feature', newFeatureApi)
```

### 数据库迁移

#### 1. 创建迁移文件
```sql
-- migrations/0009_add_new_feature.sql
CREATE TABLE new_feature_table (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name VARCHAR(100) NOT NULL,
  value TEXT,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- 创建索引
CREATE INDEX idx_new_feature_name ON new_feature_table(name);
```

#### 2. 运行迁移
```bash
# MySQL
mysql -u root -p12345 ZENAVA_LOCAL < migrations/0009_add_new_feature.sql

# SQLite
sqlite3 data/zenava.db < migrations/0009_add_new_feature.sql
```

### 前端交互

#### 使用 Fetch API
```html
<script>
  async function saveData() {
    try {
      const response = await fetch('/api/new-feature', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          name: 'test',
          value: 'test value'
        })
      })
      
      const result = await response.json()
      
      if (result.success) {
        alert('保存成功！')
        window.location.reload()
      } else {
        alert('保存失败：' + result.error)
      }
    } catch (error) {
      alert('请求失败：' + error.message)
    }
  }
</script>
```

